generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  password     String
  profileImage String?
  bio          String?
  age          Int?
  gender       String?
  city         String?
  hometown     String?
  state        String?
  firstName    String?
  lastName     String?
  phone        String?
  country      String?
  dateOfBirth  DateTime?
  travelStyle  String[] @default([])
  interests    String[] @default([])
  professionalStatus String?
  budgetRange  String?
  travelPersonality   String?
  emergencyContacts   Json?    @default("[]")
  reputationScore     Int      @default(50)
  isVerified        Boolean  @default(false)
  refreshToken     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isEmailVerified     Boolean   @default(false)
  verificationToken   String?
  verificationExpiry  DateTime?

  trips               Trip[]             @relation("UserTrips")
  tripMembers         TripMember[]
  joinRequests        JoinRequest[]
  transactions        Transaction[]
  notifications       Notification[]
  expensesPaid        Expense[]          @relation("ExpensePaidBy")
  expenseParticipants ExpenseParticipant[]
  checklistItemsAdded     ChecklistItem[] @relation("ChecklistAddedBy")
  checklistItemsCompleted ChecklistItem[] @relation("ChecklistCompletedBy")
  followers           Follow[]          @relation("Following")
  following           Follow[]          @relation("Follower")
  photos              Photo[]
  photoLikes          PhotoLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Notification {
  id      String  @id @default(uuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String
  title   String
  message String
  link    String?
  isRead  Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Trip {
  id          String   @id @default(uuid())
  name        String
  fromCity    String
  toCity      String
  startDate   DateTime
  endDate     DateTime
  budget      Float
  tripType    String
  description String?
  itinerary   String?
  isPublic    Boolean  @default(true)
  inviteCode  String?  @unique   // ← Private trips ke liye unique code

  adminId String
  admin   User   @relation("UserTrips", fields: [adminId], references: [id], onDelete: Cascade)

  members      TripMember[]
  joinRequests JoinRequest[]
  wallet       Wallet?
  checklistItems ChecklistItem[]
  photos       Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trips")
}

model Wallet {
  id          String   @id @default(uuid())
  tripId      String   @unique
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  totalBudget Float    @default(0)
  collected   Float    @default(0)
  spent       Float    @default(0)
  transactions Transaction[]
  expenses     Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model Transaction {
  id          String  @id @default(uuid())
  walletId    String
  wallet      Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  @@map("transactions")
}

model Expense {
  id          String  @id @default(uuid())
  walletId    String
  wallet      Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paidBy      String
  paidByUser  User    @relation("ExpensePaidBy", fields: [paidBy], references: [id], onDelete: Cascade)
  amount      Float
  description String
  category    String? @default("other")
  splitType   String  @default("equal")
  participants ExpenseParticipant[]
  createdAt   DateTime @default(now())

  @@map("expenses")
}

model ExpenseParticipant {
  id        String  @id @default(uuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  share     Float
  createdAt DateTime @default(now())

  @@unique([expenseId, userId])
  @@map("expense_participants")
}

model TripMember {
  id       String   @id @default(uuid())
  tripId   String
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([tripId, userId])
  @@map("trip_members")
}

model JoinRequest {
  id          String  @id @default(uuid())
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User    @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  message     String?
  status      String  @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("join_requests")
}

model ChecklistItem {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  addedById   String
  addedBy     User     @relation("ChecklistAddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  name        String
  isCompleted Boolean  @default(false)
  completedById String?
  completedBy   User?   @relation("ChecklistCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("checklist_items")
}

model Photo {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     PhotoLike[]
  createdAt DateTime @default(now())

  @@map("photos")
}

model PhotoLike {
  id      String @id @default(uuid())
  photoId String
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([photoId, userId])
  @@map("photo_likes")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}
